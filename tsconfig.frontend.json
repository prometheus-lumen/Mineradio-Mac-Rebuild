{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@frontend/*": ["./src/frontend/*"]
    },
    "lib": ["ES2019", "DOM"],
    "types": ["three"],
    "rootDir": "src/frontend",
    "noEmit": true,
    "strict": true,
    "noEmitOnError": true
  },
  "include": ["src/frontend/**/*.ts"]
}
