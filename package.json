{
  "name": "mineradio-tauri",
  "version": "2.0.4",
  "private": true,
  "description": "Mineradio Tauri 2 desktop player with a native Rust backend",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:frontend": "vite --config vite.config.mjs",
    "build": "tauri build",
    "build:frontend": "npm run typecheck && vite build --config vite.config.mjs",
    "typecheck": "tsc -p tsconfig.frontend.json --noEmit",
    "version:sync": "node scripts/sync-version.mjs",
    "release:manifest": "node scripts/create-update-manifest.mjs",
    "build:mac": "bash scripts/build-macos.sh",
    "build:mac:quiet": "CI=true bash scripts/build-macos.sh",
    "build:mac:x64": "bash scripts/build-macos.sh x64",
    "build:mac:arm64": "bash scripts/build-macos.sh arm64"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/three": "0.128.0",
    "typescript": "^7.0.2",
    "vite": "^7.0.0"
  }
}
